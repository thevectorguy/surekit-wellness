# API server port
PORT=3001

# Supabase / Postgres connection used for the live crystal catalog and orders
DATABASE_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-1-<region>.pooler.supabase.com:5432/postgres

# Google Sheet destination
GOOGLE_CONTACT_SHEET_ID=1TmdFArvDIjzyxoap_VPbXlHnG48klmzTdrDdyLpuREU

# Optional. Leave blank to use the first tab in the spreadsheet.
GOOGLE_CONTACT_SHEET_NAME=

# Service account credentials from Google Cloud.
# Share the spreadsheet with this service account email as Editor.
GOOGLE_CONTACT_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_CONTACT_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
